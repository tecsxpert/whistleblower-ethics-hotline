# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# REQUIRED — Groq API key for LLM calls. Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL — Flask dev server port (default: 5000)
AI_PORT=5000

# OPTIONAL — Enable Flask debug mode (default: false; NEVER true in production)
FLASK_DEBUG=false

# OPTIONAL — Redis URL for rate-limiter shared state across Gunicorn workers.
# Also used by services/cache.py for AI response caching (TTL: 15 min).
# In Docker Compose this is redis://redis:6379 (matches the service name).
# Locally without Redis, leave this commented out — the limiter falls back to
# in-memory storage and caching is silently disabled.
REDIS_URL=redis://redis:6379

# OPTIONAL — Path where ChromaDB stores its persistent vector data.
# In Docker this maps to the volume defined in docker-compose.yml.
CHROMA_PERSIST_DIR=./chroma_data

# OPTIONAL — Comma-separated list of allowed CORS origins (Java backend URL)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
